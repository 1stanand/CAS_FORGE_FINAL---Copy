# ─────────────────────────────────────────────────────────────────────────────
# CASForge - Environment Configuration
# Edit this file before running anything.
# Never commit this file if it contains real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_NAME=CASForge_F
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Feature repo path ─────────────────────────────────────────────────────────
# Root directory that contains all .feature files to be parsed.
FEATURES_REPO_PATH=D:\WholeREPO\Features_Claude

# ── FAISS index directory ─────────────────────────────────────────────────────
# Where the vector index files are stored.
# Defaults to <project_root>/index if left blank.
FAISS_INDEX_DIR=

# ── Embedding model ───────────────────────────────────────────────────────────
# Sentence-transformers model name (downloaded once, then cached locally).
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM (Phase 2) ─────────────────────────────────────────────────────────────
# Absolute path to the GGUF model file (Llama or Mistral).
# Example: D:\Models\llama-3.2-3b-instruct.Q4_K_M.gguf
LLM_MODEL_PATH=D:\LLM_MODEL\Meta-Llama-3-8B-Instruct-Q4_K_M.gguf

# Context window size in tokens.
LLM_CONTEXT_LENGTH=4096

# Number of model layers to offload to GPU (0 = CPU only).
LLM_GPU_LAYERS=0

# Number of CPU threads for LLM inference (0 = auto: physical core count).
# On 8GB RAM machines: set to 4 (or lower if paging is severe).
# On 16GB+ RAM machines: set to 0 (auto-detect).
LLM_NUM_THREADS=4

# Sampling temperature (0.1 = near-deterministic, good for structured output).
LLM_TEMPERATURE=0.1

# Max tokens the LLM can generate in one response.
LLM_MAX_TOKENS=1024

# ── Output (Phase 2) ──────────────────────────────────────────────────────────
# Directory where generated .feature files are written.
# Defaults to <project_root>/output if left blank.
OUTPUT_DIR=
